# --- BACKEND CONFIGURATION ---

# --- NETWORK / FRONTEND ---
CORS_ORIGIN="http://localhost:80"
API_URL="http://localhost:3000"

# --- POSTGRES LOCAL ---
POSTGRES_HOST="db"
POSTGRES_PORT="5432"
POSTGRES_DB="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_USER_READ_WRITE="supabase_admin"
POSTGRES_USER_READ_ONLY="supabase_read_only_user"

# Connection string used by the backend and storage-api
DATABASE_URL="postgresql://supabase_admin:postgres@db:5432/postgres"

# --- STORAGE API (Supabase) ---
# Base URL for local Storage API access
SUPABASE_URL="http://storage_api:5000"

# Legacy API keys used by the app/backend and storage-api
JWT_SECRET="super-secret-jwt-token-with-at-least-32-characters-long"
PGRST_JWT_SECRET="super-secret-jwt-token-with-at-least-32-characters-long"
