# --- STORAGE BACKEND ---
STORAGE_BACKEND="file"
STORAGE_PUBLIC_URL="http://localhost:5000"
GLOBAL_S3_BUCKET="storage"
REGION="local"
STORAGE_FILE_BACKEND_PATH="/var/lib/storage"
FILE_STORAGE_BACKEND_PATH="/var/lib/storage"

# --- STORAGE / AUTH SECRETS ---
ADMIN_API_KEYS="local-admin-key"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef"

# --- REDIS (Interno en Docker) ---
REDIS_URL="redis://redis:6379"

# --- SYNC (VOLUMENES) ---
# Valor por defecto: volumen nombrado de Docker.
SYNC_VOLUME_SOURCE="sync_data"
SYNC_VOLUME_TARGET="/app/sync-data"

# --- OPTIONAL APP SECRET ---
# AES_KEY is kept for compatibility with the application backend.
AES_KEY="0123456789abcdef0123456789abcdef"
