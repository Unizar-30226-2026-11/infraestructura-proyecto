# --- BACKEND CONFIGURATION ---

# --- CONFIGURACIÓN DE RED ---
CORS_ORIGIN="http://localhost:5173" # URL del frontend para CORS

# --- SUPABASE (Base de Datos & Storage) ---
# Reemplaza con los valores de Settings > Database / API en Supabase
# Se recomienda usar el Connection Pooler (puerto 6543)
DATABASE_URL="postgresql://postgres.example-id:super-secret-password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Usado por el Backend para interactuar con Storage y Auth
SUPABASE_URL="https://abcde-fg-hijk.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.un-token-muy-largo-de-ejemplo-que-nadie-debe-conocer-en-produccion"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.clave-anonima-ejemplo"

# --- REDIS (Interno en Docker) ---
# IMPORTANTE: Dentro de la red de Docker usamos el nombre del servicio 'redis'
REDIS_URL="redis://localhost:6379" 

# --- SEGURIDAD Y ENCRIPTACIÓN ---
# JWT_SECRET: Genera una cadena aleatoria larga
JWT_SECRET="zN7xP9qW2vL5mK8jR4hG1sB3tD6yF0cA"
# AES_KEY: Debe tener exactamente 32 caracteres para AES-256
AES_KEY="k9W2vL5mK8jR4hG1sB3tD6yF0cA_abc1"

# --- FRONTEND CONFIGURATION ---

# URL pública donde el navegador encontrará el backend
# No necesaria, porque el navegador no sabe qué son las viriables de entorno
API_URL="http://localhost:3000"
